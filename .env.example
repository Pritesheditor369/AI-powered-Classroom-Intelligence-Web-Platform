# Database
DATABASE_URL=postgresql://classroom_user:dev_password_change_me@localhost:5432/ai_classroom_db
POSTGRES_USER=classroom_user
POSTGRES_PASSWORD=dev_password_change_me
POSTGRES_DB=ai_classroom_db

# Redis
REDIS_URL=redis://localhost:6379

# Opensearch/Elasticsearch
OPENSEARCH_HOST=localhost:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=admin

# AWS/Cloud Storage
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET_NAME=ai-classroom-lectures
S3_ENDPOINT=http://localhost:9000

# Authentication
JWT_SECRET=your_super_secret_jwt_key_change_me
JWT_EXPIRY=7d
COGNITO_DOMAIN=your_cognito_domain.auth.us-east-1.amazoncognito.com
COGNITO_CLIENT_ID=your_client_id
COGNITO_CLIENT_SECRET=your_client_secret

# AI/LLM Services
OPENAI_API_KEY=sk-your_openai_key
OPENAI_MODEL=gpt-4
GOOGLE_CLOUD_PROJECT_ID=your_gcp_project
GOOGLE_SPEECH_TO_TEXT_API_KEY=your_gcp_key

# Backend
BACKEND_URL=http://localhost:8000
API_PORT=8000
ENV=development
LOG_LEVEL=DEBUG

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_REALTIME_URL=http://localhost:3001

# Realtime Service
REALTIME_PORT=3001
NODE_ENV=development

# Email Service (SendGrid/SES)
SENDGRID_API_KEY=your_sendgrid_key
SES_REGION=us-east-1

# Security
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
MAX_UPLOAD_SIZE_MB=500
SESSION_SECRET=your_session_secret_change_me

# Monitoring/Logging
DATADOG_API_KEY=your_datadog_key
SENTRY_DSN=your_sentry_dsn

# Feature Flags
ENABLE_REALTIME_TRANSCRIPTION=true
ENABLE_AI_NOTES_GENERATION=true
ENABLE_SYLLABUS_COMPARISON=true
ENABLE_SEMANTIC_SEARCH=true